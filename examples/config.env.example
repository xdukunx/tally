# tally configuration — copy to config.env and fill in. NEVER commit config.env.
# Bot token from @BotFather; chat_id from @userinfobot.
# If unset, tally prints notifications to stdout instead of Telegram.
export TALLY_TELEGRAM_TOKEN="123456:ABC-your-bot-token-here"
export TALLY_TELEGRAM_CHAT_ID="987654321"
