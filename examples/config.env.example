# tally configuration — copy to config.env and fill in. NEVER commit config.env.
# Bot token from @BotFather; chat_id from @userinfobot.
# If unset, tally prints notifications to stdout instead of Telegram.
export TALLY_TELEGRAM_TOKEN="123456:ABC-your-bot-token-here"
export TALLY_TELEGRAM_CHAT_ID="987654321"

# --- queue (v1.5) — defaults shown are for Mindlab-01 (a 32-core box) ---
# The scheduler and `tally submit` read these; unset means use the default.
export TALLY_TOTAL_CORES=32
export TALLY_SYSTEM_RESERVE_CORES=2      # kept idle for the OS; never scheduled
export TALLY_MAX_CORES_PER_JOB=30        # hard cap per single job
export TALLY_TOTAL_RAM_MB=32000
export TALLY_SYSTEM_RESERVE_RAM_MB=2000
export TALLY_GPU_EXCLUSIVE=1             # at most one GPU job at a time
export TALLY_SCHEDULER_INTERVAL=5        # seconds between scheduler ticks
# export TALLY_DB_PATH=                  # override queue DB location (default:
#                                        # ~/.local/share/tally/tally.db)
